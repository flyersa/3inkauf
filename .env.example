SECRET_KEY=change-me-generate-with-python3-c-import-secrets-print-secrets.token_urlsafe-32
BASE_URL=http://localhost
DATABASE_URL=sqlite+aiosqlite:////data/grocery.db

# SMTP for password reset emails
# Leave empty to log reset links to console instead of sending emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=no-reply@example.com
SMTP_USE_TLS=true

# ML model (default works out of the box, no changes needed)
ML_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Ollama (optional - enables advanced AI mode)
# If set, auto-sort uses an LLM for near-perfect sorting accuracy
# Recommended model: gemma3:4b (~3GB VRAM, fast, excellent multilingual)
OLLAMA_URL=
OLLAMA_MODEL=gemma3:4b
